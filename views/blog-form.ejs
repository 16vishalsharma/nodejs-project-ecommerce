<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= isEdit ? 'Edit Blog' : 'Create Blog' %> - E-commerce API</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <main class="container">
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error">
                <%= error %>
            </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success">
                <%= success %>
            </div>
        <% } %>

<div class="card">
    <h1><%= isEdit ? 'Edit Blog' : 'Create New Blog' %></h1>

    <form action="<%= isEdit ? `/blogs/${blog._id}?_method=PUT` : '/blogs' %>" method="POST">
        <% if (isEdit) { %>
            <input type="hidden" name="_method" value="PUT">
        <% } %>

        <h2>Blog Content</h2>

        <div class="form-group">
            <label for="title">Title *</label>
            <input type="text" id="title" name="title" value="<%= blog?.title || '' %>" required maxlength="200">
        </div>

        <div class="form-group">
            <label for="excerpt">Excerpt</label>
            <textarea id="excerpt" name="excerpt" rows="2" maxlength="500" placeholder="Brief summary of your blog post"><%= blog?.excerpt || '' %></textarea>
        </div>

        <div class="form-group">
            <label for="content">Content *</label>
            <textarea id="content" name="content" rows="10" required placeholder="Write your blog content here..."><%= blog?.content || '' %></textarea>
        </div>

        <div class="form-group">
            <label for="featuredImage">Featured Image URL</label>
            <input type="url" id="featuredImage" name="featuredImage" value="<%= blog?.featuredImage || '' %>" placeholder="https://example.com/image.jpg">
        </div>

        <div class="form-group">
            <label for="tags">Tags (comma-separated)</label>
            <input type="text" id="tags" name="tags" value="<%= blog?.tags ? blog.tags.join(', ') : '' %>" placeholder="technology, programming, web">
        </div>

        <div class="form-group">
            <label for="status">Status</label>
            <select id="status" name="status">
                <option value="draft" <%= (blog?.status === 'draft' || !blog?.status) ? 'selected' : '' %>>Draft</option>
                <option value="published" <%= blog?.status === 'published' ? 'selected' : '' %>>Published</option>
            </select>
        </div>

        <hr style="margin: 2rem 0;">

        <h2>Blogger Information</h2>

        <div class="form-group">
            <label for="bloggerName">Blogger Name *</label>
            <input type="text" id="bloggerName" name="bloggerName" value="<%= blog?.blogger?.name || '' %>" required>
        </div>

        <div class="form-group">
            <label for="bloggerEmail">Blogger Email *</label>
            <input type="email" id="bloggerEmail" name="bloggerEmail" value="<%= blog?.blogger?.email || '' %>" required>
        </div>

        <div class="form-group">
            <label for="bloggerPassword">Password *<%= isEdit ? ' (leave blank to keep current)' : '' %></label>
            <input type="password" id="bloggerPassword" name="bloggerPassword" <%= isEdit ? '' : 'required' %> minlength="6" placeholder="<%= isEdit ? 'Enter new password to change' : 'Minimum 6 characters' %>">
        </div>

        <div class="form-group">
            <label for="bloggerBio">Bio</label>
            <textarea id="bloggerBio" name="bloggerBio" rows="3" maxlength="500" placeholder="Tell readers about yourself"><%= blog?.blogger?.bio || '' %></textarea>
        </div>

        <div class="form-group">
            <label for="bloggerAvatar">Avatar URL</label>
            <input type="url" id="bloggerAvatar" name="bloggerAvatar" value="<%= blog?.blogger?.avatar || '' %>" placeholder="https://example.com/avatar.jpg">
        </div>

        <div class="form-group">
            <label for="bloggerWebsite">Website</label>
            <input type="url" id="bloggerWebsite" name="bloggerWebsite" value="<%= blog?.blogger?.website || '' %>" placeholder="https://yourwebsite.com">
        </div>

        <h3>Social Links</h3>

        <div class="form-group">
            <label for="bloggerTwitter">Twitter</label>
            <input type="text" id="bloggerTwitter" name="bloggerTwitter" value="<%= blog?.blogger?.socialLinks?.twitter || '' %>" placeholder="@username or full URL">
        </div>

        <div class="form-group">
            <label for="bloggerLinkedin">LinkedIn</label>
            <input type="text" id="bloggerLinkedin" name="bloggerLinkedin" value="<%= blog?.blogger?.socialLinks?.linkedin || '' %>" placeholder="Profile URL">
        </div>

        <div class="form-group">
            <label for="bloggerGithub">GitHub</label>
            <input type="text" id="bloggerGithub" name="bloggerGithub" value="<%= blog?.blogger?.socialLinks?.github || '' %>" placeholder="@username or profile URL">
        </div>

        <div style="margin-top: 2rem;">
            <button type="submit" class="btn"><%= isEdit ? 'Update Blog' : 'Create Blog' %></button>
            <a href="/blogs" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
    </main>

    <%- include('partials/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>
