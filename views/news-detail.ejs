<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= news.title %> - E-commerce API</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <main class="container">

<div class="card">
    <div style="margin-bottom: 1rem;">
        <a href="/news" style="text-decoration: none;">&larr; Back to News</a>
    </div>

    <div style="margin-bottom: 0.75rem;">
        <span style="background: #2563eb; color: #fff; padding: 0.25rem 0.6rem; border-radius: 4px; font-size: 0.8rem; font-weight: bold;"><%= news.category %></span>
        <span style="background: #e0e0e0; padding: 0.25rem 0.6rem; border-radius: 4px; font-size: 0.8rem; margin-left: 0.25rem;"><%= news.topic %></span>
    </div>

    <h1 style="margin-bottom: 0.75rem;"><%= news.title %></h1>

    <div style="color: #666; font-size: 0.9rem; margin-bottom: 1.5rem;">
        <span>Published: <%= new Date(news.publishedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
        <% if (news.source) { %>
            <span> | Source: <% if (news.sourceUrl) { %><a href="<%= news.sourceUrl %>" target="_blank"><%= news.source %></a><% } else { %><%= news.source %><% } %></span>
        <% } %>
    </div>

    <% if (news.imageUrl) { %>
        <img src="<%= news.imageUrl %>" alt="<%= news.title %>" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; margin-bottom: 1.5rem;">
    <% } %>

    <div style="line-height: 1.8; font-size: 1.05rem; margin-bottom: 1.5rem;">
        <%- news.summary.replace(/\n/g, '<br>') %>
    </div>

    <% if (news.tags && news.tags.length > 0) { %>
        <div style="margin-top: 1.5rem;">
            <strong>Tags: </strong>
            <% news.tags.forEach(tag => { %>
                <span style="background: #e0e0e0; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem; margin-right: 0.4rem;"><%= tag %></span>
            <% }) %>
        </div>
    <% } %>

    <div style="color: #888; font-size: 0.85rem; margin-top: 1rem;">
        Created: <%= new Date(news.createdAt).toLocaleString('en-IN') %>
    </div>
</div>
    </main>

    <%- include('partials/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>
