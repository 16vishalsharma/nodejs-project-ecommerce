<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener - E-commerce API</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>

    <main class="container">
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-error">
                <%= error %>
            </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success">
                <%= success %>
            </div>
        <% } %>

<div class="card">
    <h1>URL Shortener</h1>
    <p>Shorten any long URL into a manageable link and track clicks.</p>
    
    <form id="urlForm">
        <div class="form-group">
            <label for="originalUrl">Original URL *</label>
            <input type="url" id="originalUrl" name="originalUrl" placeholder="https://www.example.com/very/long/url" required>
        </div>
        
        <div class="form-group">
            <label for="customCode">Custom Code (Optional)</label>
            <input type="text" id="customCode" name="customCode" placeholder="my-custom-link">
            <small style="color: #666;">Leave empty for auto-generated code</small>
        </div>
        
        <div class="form-group">
            <label for="expiresInDays">Expires In (Days)</label>
            <input type="number" id="expiresInDays" name="expiresInDays" min="1" placeholder="Leave empty for no expiration">
        </div>
        
        <button type="submit" class="btn">Shorten URL</button>
    </form>
    
    <div id="urlResult" style="display: none;"></div>
</div>

<div class="card">
    <h2>Recent Shortened URLs</h2>
    <% if (urls && urls.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>Original URL</th>
                    <th>Short URL</th>
                    <th>Clicks</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% urls.forEach(url => { %>
                    <tr>
                        <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            <%= url.originalUrl %>
                        </td>
                        <td>
                            <a href="<%= url.shortUrl %>" target="_blank"><%= url.shortUrl %></a>
                        </td>
                        <td><%= url.clicks %></td>
                        <td><%= new Date(url.createdAt).toLocaleDateString() %></td>
                        <td>
                            <a href="/api/urls/stats/<%= url.shortCode %>" class="btn btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Stats</a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>No shortened URLs yet. Create one above!</p>
    <% } %>
</div>
    </main>

    <%- include('partials/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>

